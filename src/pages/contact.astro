---
import Layout from "@layouts/Global.astro";
import Toast from "@components/Toast.astro";
import { actions, isInputError } from "astro:actions";
import Footer from "@components/Footer.astro";
const result = Astro.getActionResult(actions.send);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
import { TURNSTILE_CLIENT } from "astro:env/client";
---

<Layout title="Contact - barab.">
    <script
        is:inline
        src="https://challenges.cloudflare.com/turnstile/v0/api.js"
        async
        defer></script>

    <script is:inline>
        button = document.getElementById("submit-btn");
        function onTurnstileSuccess(token) {
            console.log("Turnstile success:", token);
            button.disabled = false;
        }
        function onTurnstileError(errorCode) {
            console.error("Turnstile error:", errorCode);
            button.disabled = true;
        }
        function onTurnstileExpired() {
            console.warn("Turnstile token expired");
            button.disabled = true;
        }
    </script>
    <div class="flex flex-col w-full items-center bg-[#008080] p-5">
        <div class="flex flex-col sm:w-3/4 w-full gap-3">
            <form
                method="post"
                action={actions.send}
                class="flex flex-col gap-5 text-sm w-full"
            >
                <div>
                    <input
                        transition:persist
                        name="email"
                        type="email"
                        class="rounded-md focus:placeholder-[#008080] w-full"
                        placeholder="Email"
                        aria-describedby="error"
                    />
                    {
                        inputErrors.email && (
                            <p class="text-gray-700 select-none">
                                {" "}
                                {inputErrors.email.join(",")}
                            </p>
                        )
                    }
                </div>
                <div>
                    <textarea
                        transition:persist
                        class="rounded-md focus:placeholder-[#008080] w-full"
                        placeholder="Message"
                        name="message"
                        rows="5"
                        aria-describedby="error"
                        required></textarea>
                    {
                        inputErrors.message && (
                            <p class="text-gray-700 select-none">
                                {" "}
                                {inputErrors.message.join(",")}
                            </p>
                        )
                    }
                </div>
                <div class="flex flex-col items-start gap-3">
                    <p class="text-gray-700 select-none">
                        Email is not required.
                    </p>
                    <div
                        class="cf-turnstile"
                        data-sitekey={TURNSTILE_CLIENT}
                        data-theme="auto"
                        data-size="flexible"
                        data-callback="onTurnstileSuccess"
                        data-error-callback="onTurnstileError"
                        data-expired-callback="onTurnstileExpired"
                    >
                    </div>
                    <button
                        type="submit"
                        class="bg-[#fbffee] cursor-pointer p-8 rounded-md text-gray-500 hover:text-gray-700 hover:font-bold py-1 border-gray-500"
                        id="submit-btn"
                        disabled
                    >
                        Submit
                    </button>
                </div>
            </form>
        </div>
    </div>

    {
        result && !result.error && (
            <Toast success={true} message={result.data.message} />
        )
    }
    {
        result?.error && (
            <Toast
                success={false}
                message={{
                    title: "Error",
                    text: "Error while sending your message. Retry or email us",
                }}
            />
        )
    }
    <Footer />
</Layout>
