---
import Layout from "@layouts/Global.astro";
import Loading from "@components/Loading.astro";
---

<Layout title="About - barab.">
    <Loading id="loading" />
    <canvas id="3dhouse" class="fixed top-0"></canvas>
    <script>
        import { Application } from "@splinetool/runtime";

        const canvas = document.getElementById("3dhouse") as HTMLCanvasElement;
        const spline = new Application(canvas);

        spline
            .load("/house.splinecode", {
                credentials: "include",
                mode: "no-cors",
            })
            .then(async () => {
                var status = await (await fetch("/presence")).text();
                spline.setVariable("status", status);
                var spotify = await (await fetch("/presence/spotify")).json();
                if (spotify) {
                    spline.setVariable(
                        "music",
                        "listening " + (spotify as any).details,
                    );
                }

                var vscode = await (await fetch("/presence/vscode")).json();
                if (vscode) {
                    spline.setVariable("code", (vscode as any).details);
                }
            });
    </script>
</Layout>
