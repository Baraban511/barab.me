---
import "@assets/styles/base.css";
import "@assets/styles/icons.css";
import { Font } from "astro:assets";
import Header from "@components/Header.astro";
import { ClientRouter } from "astro:transitions";
const { title, active } = Astro.props;
---

<html lang="en" class="scroll-smooth" transition:animate="fade">
	<head>
		<meta charset="utf-8" />

		<ClientRouter />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<Font cssVariable="--font-noto" preload/>
		<title>{title ? title : "barab."}</title>
		<meta name="title" content="barab. - Developer" />
		<meta
			name="description"
			content="I'm barab, an in learning developer. This website is my portfolio."
		/>
		<link rel="canonical" href="https://barab.me/" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="barab." />
		<meta property="og:url" content="https://barab.me" />
		<meta property="og:image" content="https://barab.me/logo.png" />
		<meta
			property="og:description"
			content="I'm barab, an in learning developer. This website is my portfolio."
		/>
		<link rel="sitemap" href="/sitemap-index.xml" />
	</head>
	<body class="flex flex-col bg-[#fbffee] h-screen">
		<Header active={active || Astro.url.pathname} />
		<slot />
	</body>
</html>
